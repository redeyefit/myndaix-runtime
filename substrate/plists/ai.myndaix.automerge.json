{
  "label": "ai.myndaix.automerge",
  "roles": ["factory"],
  "mutating": true,
  "program": ["/bin/bash", "{DEPLOY_CLONE}/orchestrator/automerge-tick.sh"],
  "schedule": {"StartCalendarInterval": {"Minute": 30}},
  "stdout": "{MYNDAIX_HOME}/orchestrator/automerge.out",
  "env": {"MYNDAIX_DSN": "MYNDAIX_DSN", "MYNDAIX_HOME": "MYNDAIX_HOME", "MYNDAIX_AUTOMERGE_AUTHORS": "AUTHOR_ALLOWLIST", "PATH": "AGENT_CLI_PATH"},
  "env_literal": {"PLAY_SELF": "{DEPLOY_CLONE}/orchestrator/play-review.sh"}
}
