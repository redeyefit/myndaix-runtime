# MyndAIX two-machine substrate — per-machine config.
#
# Copy to $MYNDAIX_HOME/config.env, `chmod 600`, and fill in. This file is PARSED,
# never sourced (see substrate/config_parse.py) — values are opaque literals, so no
# shell metacharacters are interpreted. Lines are strict KEY=value; # starts a comment.
#
# NOTHING here is a secret store — API keys/tokens stay in $MYNDAIX_HOME/.secrets.

# Role of this machine. `lab` = interactive dev (serve + pre-push review hook, autonomy
# OFF). `factory` = the always-on brain (serve + all autonomy loops + reconcile poll).
MACHINE_ROLE=lab

# Absolute path to the mutable state root (the "$MYNDAIX_HOME" the whole system uses).
# Holds config.env, .secrets, the deploy clone, the work area, sentinels, RUNNING_SHA,
# logs, and the local Postgres data.
MYNDAIX_HOME=/Users/you/.myndaix

# The live ledger DSN. FACTORY MUST pin 127.0.0.1 (the Mini's IPv6 loopback wedges).
MYNDAIX_DSN=postgresql://127.0.0.1/runtime

# OPTIONAL: a dedicated scratch DB for autonomous verification (play-fix worktree tests).
# A PR's undeployed migration / test writes must never touch the live ledger. If unset,
# play-fix's sandbox stays network-denied as today (no DB reachable from the sandbox).
# MYNDAIX_WORK_DSN=postgresql://127.0.0.1/runtime_work

# Operator inbox — where review verdicts / drift alerts are dropped. Required on factory.
OPERATOR_INBOX=/Users/you/.myndaix/bridge/inbox/jefe

# Comma-separated GitHub logins allowed to author auto-mergeable PRs. Required on factory.
# FAIL-CLOSED: if this is missing/empty on a factory machine, config validation aborts —
# an empty allowlist would be allow-all.
AUTHOR_ALLOWLIST=your-gh-login

# OPTIONAL: colon-separated absolute dirs to prepend to PATH so launchd finds agent CLIs.
# AGENT_CLI_PATH=/opt/homebrew/bin:/Users/you/.local/bin

# OPTIONAL: FACTORY reconcile poll interval in seconds (floor 60; default 900 = 15 min).
# POLL_INTERVAL_S=900

# OPTIONAL: override the deploy-clone location (default: $MYNDAIX_HOME/deploy/myndaix-runtime).
# DEPLOY_CLONE=/Users/you/.myndaix/deploy/myndaix-runtime

# ---- Inbox Assistant (factory-only morning-brief tick; ALL keys optional) ----

# OPTIONAL: comma-separated Gmail addresses the brief pulls. Absent/empty = component OFF.
# INBOX_ACCOUNTS=you@gmail.com,you.work@gmail.com

# OPTIONAL: 1Password vault holding gmail-oauth-client + gmail-rt-<email> items (default Automation).
# INBOX_OP_VAULT=Automation

# OPTIONAL: first-run backfill window in days when no cursor exists yet (default 90).
# INBOX_BACKFILL_DAYS=90

# OPTIONAL: which account's Drive mirrors the brief (must be one of INBOX_ACCOUNTS); empty = off.
# INBOX_DRIVE_ACCOUNT=you@gmail.com

# OPTIONAL: Notion database id the brief is mirrored to as a row; empty = off.
# INBOX_NOTION_DB=00000000000000000000000000000000

# OPTIONAL: E.164 phone for the "brief is ready" iMessage ping; empty = off.
# INBOX_IMESSAGE_TO=+13105551234
